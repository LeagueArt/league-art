# === Supabase (필수: 로그인/회원가입/마이페이지/관리자 기능) ===
# 미설정 시 사이트는 정상 동작하지만 인증/DB 기능은 비활성화됩니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키 — 서버 전용(절대 NEXT_PUBLIC_ 접두사 금지)
SUPABASE_SERVICE_ROLE_KEY=

# === 관리자 (쉼표로 구분된 이메일 목록) ===
ADMIN_EMAILS=

# === 이큐어 제3자 제공 연동 ===
# 데이터 export 토글(서버 전용). 실제 제공 합의 시에만 true.
EQURE_SHARING_ENABLED=false
EQURE_EXPORT_TOKEN=
# 회원가입·마이페이지에 이큐어 제3자 제공 "동의 화면" 노출 여부(공개). 미설정=숨김.
NEXT_PUBLIC_EQURE_CONSENT_ENABLED=

# === SEO / 사이트 메타 ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# === 방문분석 GA4 (계약 별첨 A-6) — 리그아트 발급 측정 ID(G-XXXXXXX). 미설정 시 미로드 ===
NEXT_PUBLIC_GA_MEASUREMENT_ID=
